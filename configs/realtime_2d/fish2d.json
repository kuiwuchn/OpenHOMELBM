{
  "name": "fish2d_default",
  "env": {
    "class": "FishLBMEnv",
    "xml_path": "envs/lbm/fish/fish_2d_v3.xml"
  },
  "lbm": {
    "nx": 400,
    "ny": 600,
    "lbm_scale": 0.2,
    "per_frame_steps": 10
  },
  "render": {
    "type": "vorticity",
    "output_height": 720,
    "mujoco_width": 640,
    "mujoco_height": 640,
    "vmax_scale": 0.2,
    "opengl_lbm_vmax": 1.0,
    "window_name": "Fish2D Realtime Control",
    "record_fps": 30
  },
  "camera": {
    "follow": true,
    "follow_body": "root",
    "distance": 0.75,
    "azimuth": 90.0,
    "elevation": -90.0,
    "lookat": [0.0, -0.16, 0.03]
  },
  "control": {
    "dt": 0.01,
    "warmup_steps": 10,
    "transition_steps": 24,
    "start_mode": "idle"
  },
  "controls": {
    "w": "forward",
    "a": "turn_left",
    "d": "turn_right",
    "s": "idle",
    "f": "fast",
    "x": "slow"
  },
  "presets": {
    "forward": {
      "type": "sine",
      "components": [
        {"amp": 0.65, "freq": 2.4, "phase": 0.0, "bias": 0.0},
        {"amp": 0.95, "freq": 2.4, "phase": 1.35, "bias": 0.0}
      ]
    },
    "slow": {
      "type": "sine",
      "components": [
        {"amp": 0.45, "freq": 1.5, "phase": 0.0, "bias": 0.0},
        {"amp": 0.70, "freq": 1.5, "phase": 1.35, "bias": 0.0}
      ]
    },
    "fast": {
      "type": "sine",
      "components": [
        {"amp": 0.75, "freq": 3.1, "phase": 0.0, "bias": 0.0},
        {"amp": 1.00, "freq": 3.1, "phase": 1.35, "bias": 0.0}
      ]
    },
    "turn_left": {
      "type": "sine",
      "components": [
        {"amp": 0.55, "freq": 2.0, "phase": 0.0, "bias": 0.28},
        {"amp": 0.85, "freq": 2.0, "phase": 1.25, "bias": 0.18}
      ]
    },
    "turn_right": {
      "type": "sine",
      "components": [
        {"amp": 0.55, "freq": 2.0, "phase": 0.0, "bias": -0.28},
        {"amp": 0.85, "freq": 2.0, "phase": 1.25, "bias": -0.18}
      ]
    },
    "idle": {
      "type": "constant",
      "values": [0.0, 0.0]
    }
  }
}
