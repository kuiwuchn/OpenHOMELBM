<mujoco model="Starfish3D_PlanarSwimmer">

    <compiler angle="degree" inertiafromgeom="true"/>
    <option timestep="0.01" gravity="0 0 0" integrator="RK4"/>

    <default>
        <joint damping="0.2" stiffness="0" armature="0.02"/>
        <motor ctrlrange="-1 1" ctrllimited="true"/>
        <geom solref="0.002 1" solimp="0.9 0.95 0.001"/>
    </default>

    <asset>
        <material name="center_mat" rgba="1.0 0.4 0.2 1"/>
        <material name="leg_mat" rgba="1.0 0.6 0.3 1"/>
    </asset>

    <worldbody>
        <body name="center" pos="0 0 0">
            <freejoint name="root_joint"/>

            <!-- Center body: cylinder matching leg height -->
            <!-- size="radius half_height", half_height=0.02 matches leg Z -->
            <!-- density=8000, V=π×0.02²×0.04≈5.03e-5 m³ → mass≈0.40 kg -->
            <geom name="center_geom" type="cylinder"
                  size="0.02 0.02"
                  pos="0 0 0"
                  material="center_mat"
                  density="8000"/>

            <!-- Leg 0: +Y direction (vertical paddle blade) -->
            <!-- Thin X, long Y, and tall Z increase frontal area. -->
            <!-- density=5000, volume=0.01×0.14×0.04=5.6e-5 m³ → mass≈0.28 kg -->
            <body name="leg_0" pos="0 0.02 0">
                <joint name="leg_0_yaw" type="hinge" axis="0 0 1" limited="true" range="-50 50"/>

                <geom name="leg_0_geom" type="box"
                      size="0.005 0.07 0.02"
                      pos="0 0.07 0"
                      material="leg_mat"
                      density="5000"/>
            </body>

            <!-- Leg 1: +X direction (vertical paddle blade) -->
            <body name="leg_1" pos="0.02 0 0">
                <joint name="leg_1_yaw" type="hinge" axis="0 0 1" limited="true" range="-50 50"/>

                <geom name="leg_1_geom" type="box"
                      size="0.07 0.005 0.02"
                      pos="0.07 0 0"
                      material="leg_mat"
                      density="5000"/>
            </body>

            <!-- Leg 2: -Y direction (vertical paddle blade) -->
            <body name="leg_2" pos="0 -0.02 0">
                <joint name="leg_2_yaw" type="hinge" axis="0 0 1" limited="true" range="-50 50"/>

                <geom name="leg_2_geom" type="box"
                      size="0.005 0.07 0.02"
                      pos="0 -0.07 0"
                      material="leg_mat"
                      density="5000"/>
            </body>

            <!-- Leg 3: -X direction (vertical paddle blade) -->
            <body name="leg_3" pos="-0.02 0 0">
                <joint name="leg_3_yaw" type="hinge" axis="0 0 1" limited="true" range="-50 50"/>

                <geom name="leg_3_geom" type="box"
                      size="0.07 0.005 0.02"
                      pos="-0.07 0 0"
                      material="leg_mat"
                      density="5000"/>
            </body>
        </body>

        <light directional="true" diffuse="0.9 0.9 0.9" pos="0 0 3" dir="0 0 -1"/>
    </worldbody>

    <actuator>
        <!-- Yaw position controllers (planar swimming, no pitch) -->
        <!-- Matched to eel parameters: kp=2.0, kv=0.2, forcerange=±1.0 -->
        <position name="pos_leg_0_yaw" joint="leg_0_yaw" kp="2.0" kv="0.2" ctrlrange="-0.873 0.873" forcerange="-1.0 1.0"/>
        <position name="pos_leg_1_yaw" joint="leg_1_yaw" kp="2.0" kv="0.2" ctrlrange="-0.873 0.873" forcerange="-1.0 1.0"/>
        <position name="pos_leg_2_yaw" joint="leg_2_yaw" kp="2.0" kv="0.2" ctrlrange="-0.873 0.873" forcerange="-1.0 1.0"/>
        <position name="pos_leg_3_yaw" joint="leg_3_yaw" kp="2.0" kv="0.2" ctrlrange="-0.873 0.873" forcerange="-1.0 1.0"/>
    </actuator>
</mujoco>
