<mujoco model="Fish2D_Swimmer_Obstacle">

    <compiler angle="degree" inertiafromgeom="true"/>
    <option timestep="0.01" gravity="0 0 0" integrator="RK4"/>

    <default>
        <joint damping="0.05" stiffness="0" armature="0.01"/>
        <motor ctrlrange="-1 1" ctrllimited="true"/>
        <geom solref="0.001 1" solimp="0.9 0.95 0.001"/>
    </default>

    <asset>
        <material name="head"    rgba="0.2 0.6 0.9 1"/>
        <material name="body"    rgba="0.4 0.8 1.0 1"/>
        <material name="tail"    rgba="0.6 1.0 1.0 1"/>
        <material name="obstacle" rgba="0.5 0.3 0.3 1"/>
    </asset>

    <worldbody>
        <geom type="plane" size="5 5 0.1" material="head" rgba="0.1 0.1 0.1 1" pos="0 0 0"/>

        <!-- 静态障碍物 - 长方形横在鱼尾上方 -->
        <body name="obstacle" pos="0 1.625 0.05">
            <!-- 无 joint，静态刚体 -->
            <geom name="obstacle_geom" type="box"
                  size="0.50 0.05 0.02"
                  material="obstacle"
                  density="10000"/>
        </body>

        <!-- 鱼：头朝 -y 方向 (向下)，尾朝 +y 方向 (向上) -->
        <body name="root" pos="0 0 0.05">
            <joint name="free_xy" type="free"/>

            <!-- 头部：朝 -y 方向 -->
            <geom name="head_geom" type="capsule"
                  fromto="0 0 0  0 -0.1 0"
                  size="0.04"
                  material="head"
                  density="500"/>

            <!-- 身体中段：在头部后方 (+y 方向) -->
            <body name="body" pos="0 0 0">
                <joint name="joint1" type="hinge" axis="0 0 1" range="-45 45"/>
                
                <geom name="body_geom" type="capsule"
                      fromto="0 0 0  0 0.1 0"
                      size="0.035"
                      material="body"
                      density="500"/>

                <!-- 尾部：在身体后方 (+y 方向) -->
                <body name="tail" pos="0 0.1 0">
                    <joint name="joint2" type="hinge" axis="0 0 1" range="-60 60"/>

                    <!-- 尾柄：细长连接段 -->
                    <geom name="tail_stem" type="capsule"
                          fromto="0 0 0  0 0.08 0"
                          size="0.02"
                          material="tail"
                          density="500"/>

                    <!-- 尾鳍：宽大的推水面 -->
                    <geom name="tail_fin" type="ellipsoid"
                          size="0.06 0.04 0.02"
                          pos="0 0.1 0"
                          material="tail"
                          density="500"/>
                </body>
            </body>
        </body>
        <light directional="true" diffuse="0.9 0.9 0.9" pos="0 0 5" dir="0 0 -1"/>
    </worldbody>

    <actuator>
        <motor joint="joint1" gear="0.15"/>
        <motor joint="joint2" gear="0.2"/>
    </actuator>

</mujoco>
