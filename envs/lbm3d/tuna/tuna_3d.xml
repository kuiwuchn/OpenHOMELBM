<mujoco model="Tuna3D_Swimmer">
    <!--
    Tuna-like 3D Robot for LBM-MuJoCo Coupled Simulation (v16)

    Reference: SHORT flattened cylinder body with pointed nose (fish snout)
      - Body: FLATTENED CYLINDER mesh (tuna_body.stl)
        Oblate elliptical cross-section built into mesh (W:H ≈ 1.55:1)
        Pointed conical nose (fish mouth), constant radius middle, rounded tail
        scale="1.8 1.2 1.8" in XML — WIDER+SHORTER body (~150mm long, ~34mm wide)
        Purpose: large top/bottom surfaces resist roll (anti-capsize)
      - Shark-style streamlined fins (mesh-based, NACA airfoil profile):
          4 fins (2 pectoral front + 2 pelvic rear, pitch-only) — sickle/falcate shape,
          swept back, thin airfoil cross-section for low drag
      - 5-segment tail (capsule) — offset from body to avoid overlap
        tail_0 is a passive anchor segment (held at 0° by actuator) that
        decouples tail oscillation from body, reducing body tilt.

    Structure:
      head (freejoint, 6DOF root)
        body_geom       — torpedo body mesh (tuna_body.stl)
        pectoral_right (1DOF: pitch)    — right pectoral fin (mesh)
        pectoral_left  (1DOF: pitch)    — left pectoral fin (mesh)
        pelvic_right   (1DOF: pitch)    — right pelvic fin (mesh)
        pelvic_left    (1DOF: pitch)    — left pelvic fin (mesh)
        tail_0 (2DOF: yaw + pitch)      — tail capsule 0 (passive anchor)
          tail_1 (2DOF: yaw + pitch)    — tail capsule 1
            tail_2 (2DOF: yaw + pitch)  — tail capsule 2
              tail_3 (2DOF: yaw + pitch)— tail capsule 3
                tail_4 (2DOF: yaw + pitch)— tail capsule 4

    Biomechanical design:
      - Fins: 4 shark-style streamlined mesh fins (NACA airfoil profile)
          with sickle/falcate planform. Thin (3.5%), swept back, high aspect
          ratio. 2 pectoral (front) + 2 pelvic (rear), 1 DOF each (pitch =
          up/down flap) to actively counteract roll from tail propeller
          rotation. Mesh geometry provides realistic hydrodynamic interaction.
      - Tail: propeller-mode rotation via yaw+pitch joints — generates
          forward thrust by synchronized circular motion.
        yaw >> pitch range, stiff proximal → flexible distal
        WIDE joint ranges for aggressive tail whipping & turning

    Total actuators: 4 (fins) + 5*2 (tail) = 14 DOF
    tail_0 actuators are always held at 0 (passive anchor).
    Coordinate: X=lateral(right+), Y=forward, Z=up
    -->

    <compiler angle="degree" inertiafromgeom="true" meshdir="meshes/"/>
    <option timestep="0.01" gravity="0 0 0" integrator="RK4"/>

    <default>
        <joint damping="0.20" stiffness="0" armature="0.02"/>
        <motor ctrlrange="-1 1" ctrllimited="true"/>
        <!-- <geom solref="0.002 1" solimp="0.9 0.95 0.001"/> -->
        <geom solref="0.002 1" solimp="0.9 0.95 0.001" contype="0" conaffinity="0"/>
    </default>

    <asset>
        <!-- Materials -->
        <material name="body_mat"      rgba="0.96 0.80 0.82 1"/>
        <material name="tail_mat"      rgba="0.90 0.88 0.85 1"/>
        <material name="fin_mat"       rgba="0.25 0.25 0.28 1"/>

        <!-- Body mesh (generated by tools/generate_tuna_meshes.py)
             FLATTENED CYLINDER with pointed nose (fish snout):
             Oblate elliptical cross-section (W:H ≈ 1.55:1)
             Conical nose → constant radius middle → rounded tail
             Flat shape is native in STL, 1x scale — short body close to tail length -->
        <mesh name="body_mesh" file="tuna_body.stl" scale="1.8 1.2 1.8"/>

        <!-- Pectoral fin meshes (generated by tools/generate_tuna_meshes.py)
             Sickle/falcate shape with NACA airfoil cross-section:
             span=32mm, root_chord=14mm, tip_chord=2mm, thickness=3.5%
             Sharp leading edge, strong backward sweep, high aspect ratio -->
        <mesh name="fin_R_mesh" file="tuna_fin_front_R.stl" scale="2 2 2"/>
        <mesh name="fin_L_mesh" file="tuna_fin_front_L.stl" scale="2 2 2"/>

        <!-- Pelvic (rear) fin meshes — same sickle/falcate shape, slightly smaller -->
        <mesh name="fin_rear_R_mesh" file="tuna_fin_rear_R.stl" scale="1.8 1.8 1.8"/>
        <mesh name="fin_rear_L_mesh" file="tuna_fin_rear_L.stl" scale="1.8 1.8 1.8"/>
    </asset>

    <worldbody>
        <!-- ============ HEAD (root body with freejoint) ============ -->
        <body name="head" pos="0 0 0">
            <freejoint name="root_joint"/>

            <!-- Main body: flattened cylinder mesh -->
            <geom name="body_geom" type="mesh" mesh="body_mesh"
                  material="body_mat"
                  density="4000"/>

            <!-- ============ SHARK-STYLE STREAMLINED FINS ============ -->
            <!-- Pectoral fins using mesh geometry (NACA airfoil profile).
                 Sickle/falcate planform with swept-back shape.
                 Mesh origin is at fin root; fin extends outward in ±X.
                 1 DOF each: pitch (hinge around Y-axis) = up/down flap.
                 Positioned at mid-body sides, slightly forward and below
                 center for realistic shark-like placement. -->

            <!-- Right pectoral fin (+X side, front) — lowered to body midline -->
            <body name="fin_right" pos="0.025 0.006 0.0">
                <joint name="fin_right_pitch" type="hinge" axis="0 1 0"
                       limited="true" range="-50 50"/>
                <geom name="fin_right_geom" type="mesh" mesh="fin_R_mesh"
                      material="fin_mat"
                      density="250"/>
            </body>

            <!-- Left pectoral fin (-X side, front, mirrored mesh) -->
            <body name="fin_left" pos="-0.025 0.006 0.0">
                <joint name="fin_left_pitch" type="hinge" axis="0 1 0"
                       limited="true" range="-50 50"/>
                <geom name="fin_left_geom" type="mesh" mesh="fin_L_mesh"
                      material="fin_mat"
                      density="250"/>
            </body>

            <!-- Right pelvic fin (+X side, rear) — lowered to body midline -->
            <body name="fin_rear_right" pos="0.022 -0.024 0.0">
                <joint name="fin_rear_right_pitch" type="hinge" axis="0 1 0"
                       limited="true" range="-50 50"/>
                <geom name="fin_rear_right_geom" type="mesh" mesh="fin_rear_R_mesh"
                      material="fin_mat"
                      density="250"/>
            </body>

            <!-- Left pelvic fin (-X side, rear, mirrored mesh) -->
            <body name="fin_rear_left" pos="-0.022 -0.024 0.0">
                <joint name="fin_rear_left_pitch" type="hinge" axis="0 1 0"
                       limited="true" range="-50 50"/>
                <geom name="fin_rear_left_geom" type="mesh" mesh="fin_rear_L_mesh"
                      material="fin_mat"
                      density="250"/>
            </body>

            <!-- ============ TAIL: 4 capsule segments ============ -->
            <!-- Tail starts well behind body rear end (Y=-0.050 at 1x)
                 Gap ensures tail capsule does not embed into body mesh.
                 Each segment: radius 0.008m, length ~0.025m
                 2 DOF: yaw (around Z) + pitch (around X) -->

            <!-- Tail Segment 0 (passive anchor) — decouples tail oscillation from body.
                 Held at 0° by stiff actuator; absorbs reaction torque via damping.
                 Gap ensures tail capsule does not embed into body mesh. -->
            <body name="tail_0" pos="0 -0.066 0">
                <joint name="t0_yaw" type="hinge" axis="0 0 1"
                       limited="true" range="-30 30"/>
                <joint name="t0_pitch" type="hinge" axis="1 0 0"
                       limited="true" range="-30 30"/>

                <geom name="tail_0_geom" type="capsule"
                      fromto="0 0 0  0 -0.020 0"
                      size="0.006"
                      material="tail_mat"
                      density="500"/>  <!-- anchor: heaviest, short & stiff -->

                <!-- Tail Segment 1 (proximal active) -->
                <!-- Tail: dual-mode (serpentine undulation for cold-start + rudder for cruising)
                     Yaw: large range + high force for undulation thrust generation
                     Pitch: LARGE range for aggressive vertical maneuvering + tilt angle -->
                <body name="tail_1" pos="0 -0.022 0">
                    <joint name="t1_yaw" type="hinge" axis="0 0 1"
                           limited="true" range="-90 90"/>
                    <joint name="t1_pitch" type="hinge" axis="1 0 0"
                           limited="true" range="-80 80"/>

                    <geom name="tail_1_geom" type="capsule"
                          fromto="0 0 0  0 -0.025 0"
                          size="0.005"
                          material="tail_mat"
                          density="400"/>  <!-- proximal: heaviest -->

                <!-- Tail Segment 2 -->
                <body name="tail_2" pos="0 -0.027 0">
                    <joint name="t2_yaw" type="hinge" axis="0 0 1"
                           limited="true" range="-110 110"/>
                    <joint name="t2_pitch" type="hinge" axis="1 0 0"
                           limited="true" range="-95 95"/>

                    <geom name="tail_2_geom" type="capsule"
                          fromto="0 0 0  0 -0.025 0"
                          size="0.004"
                          material="tail_mat"
                          density="250"/>

                    <!-- Tail Segment 3 -->
                    <body name="tail_3" pos="0 -0.027 0">
                        <joint name="t3_yaw" type="hinge" axis="0 0 1"
                               limited="true" range="-130 130"/>
                        <joint name="t3_pitch" type="hinge" axis="1 0 0"
                               limited="true" range="-115 115"/>

                        <geom name="tail_3_geom" type="capsule"
                              fromto="0 0 0  0 -0.025 0"
                              size="0.004"
                              material="tail_mat"
                              density="150"/>  <!-- lighter distal -->

                        <!-- Tail Segment 4 (distal) -->
                        <body name="tail_4" pos="0 -0.027 0">
                            <joint name="t4_yaw" type="hinge" axis="0 0 1"
                                   limited="true" range="-150 150"/>
                            <joint name="t4_pitch" type="hinge" axis="1 0 0"
                                   limited="true" range="-135 135"/>

                            <geom name="tail_4_geom" type="capsule"
                                  fromto="0 0 0  0 -0.025 0"
                                  size="0.003"
                                  material="tail_mat"
                                  density="100"/>  <!-- lightest tip -->
                            </body>
                        </body>
                    </body>
                </body>
            </body>
        </body>

        <light directional="true" diffuse="0.9 0.9 0.9" pos="0 0 3" dir="0 0 -1"/>
    </worldbody>

    <actuator>
        <!--
        Actuator layout (14 DOFs — 4 fins + 10 tail):
          Front fins (2 DOFs):
            [0]  fin_right_pitch       Right pectoral fin: up/down flap
            [1]  fin_left_pitch        Left pectoral fin: up/down flap
          Rear fins (2 DOFs):
            [2]  fin_rear_right_pitch  Right pelvic fin: up/down flap
            [3]  fin_rear_left_pitch   Left pelvic fin: up/down flap
          Tail (10 DOFs):
            [4]  t0_yaw                Tail seg0: passive anchor yaw (held at 0)
            [5]  t0_pitch              Tail seg0: passive anchor pitch (held at 0)
            [6]  t1_yaw                Tail seg1: lateral swing
            [7]  t1_pitch              Tail seg1: vertical pitch
            [8]  t2_yaw                Tail seg2: lateral swing
            [9]  t2_pitch              Tail seg2: vertical pitch
            [10] t3_yaw                Tail seg3: lateral swing
            [11] t3_pitch              Tail seg3: vertical pitch
            [12] t4_yaw                Tail seg4: lateral swing (largest range)
            [13] t4_pitch              Tail seg4: vertical pitch
        -->

        <!-- Pectoral fins (front, shark-style): 1 DOF each (pitch = up/down flap)
             Counter-flap to cancel roll torque from tail propeller rotation.
             Scaled 2x mesh, lowered to body midline. Range ±50° = ±0.873 rad. -->
        <position name="pos_fin_right" joint="fin_right_pitch" kp="0.8" kv="0.12"
                  ctrlrange="-0.873 0.873" forcerange="-0.8 0.8"/>
        <position name="pos_fin_left"  joint="fin_left_pitch"  kp="0.8" kv="0.12"
                  ctrlrange="-0.873 0.873" forcerange="-0.8 0.8"/>

        <!-- Pelvic fins (rear, shark-style): 1 DOF each (pitch = up/down flap)
             Additional roll stabilization closer to tail. Same range as front. -->
        <position name="pos_fin_rear_right" joint="fin_rear_right_pitch" kp="0.7" kv="0.10"
                  ctrlrange="-0.873 0.873" forcerange="-0.7 0.7"/>
        <position name="pos_fin_rear_left"  joint="fin_rear_left_pitch"  kp="0.7" kv="0.10"
                  ctrlrange="-0.873 0.873" forcerange="-0.7 0.7"/>

        <!-- Tail segments: 2 DOF each
             Propeller-mode rotation: yaw+pitch with 90° phase offset
             produce circular tail motion for forward thrust.
             Yaw range >> Pitch range; stiff proximal → flexible distal -->
        <!-- Segment 0 (passive anchor — stiff, held at 0° to decouple tail from body) -->
        <position name="pos_t0_yaw"   joint="t0_yaw"   kp="1.2" kv="0.20"
                  ctrlrange="-0.524 0.524" forcerange="-0.8 0.8"/>
        <position name="pos_t0_pitch" joint="t0_pitch" kp="1.2" kv="0.20"
                  ctrlrange="-0.524 0.524" forcerange="-0.8 0.8"/>

        <!-- Segment 1 (proximal active — wide yaw for aggressive turning) -->
        <position name="pos_t1_yaw"   joint="t1_yaw"   kp="0.8" kv="0.12"
                  ctrlrange="-1.571 1.571" forcerange="-0.5 0.5"/>
        <position name="pos_t1_pitch" joint="t1_pitch" kp="0.7" kv="0.12"
                  ctrlrange="-1.396 1.396" forcerange="-0.4 0.4"/>

        <!-- Segment 2 (wave propagation — wide yaw amplitude) -->
        <position name="pos_t2_yaw"   joint="t2_yaw"   kp="0.6" kv="0.10"
                  ctrlrange="-1.920 1.920" forcerange="-0.4 0.4"/>
        <position name="pos_t2_pitch" joint="t2_pitch" kp="0.5" kv="0.10"
                  ctrlrange="-1.658 1.658" forcerange="-0.35 0.35"/>

        <!-- Segment 3 (wave amplification — very large yaw swing) -->
        <position name="pos_t3_yaw"   joint="t3_yaw"   kp="0.5" kv="0.08"
                  ctrlrange="-2.269 2.269" forcerange="-0.35 0.35"/>
        <position name="pos_t3_pitch" joint="t3_pitch" kp="0.4" kv="0.07"
                  ctrlrange="-2.007 2.007" forcerange="-0.25 0.25"/>

        <!-- Segment 4 (distal — extreme yaw for tail whip, maximum flexibility) -->
        <position name="pos_t4_yaw"   joint="t4_yaw"   kp="0.35" kv="0.06"
                  ctrlrange="-2.618 2.618" forcerange="-0.25 0.25"/>
        <position name="pos_t4_pitch" joint="t4_pitch" kp="0.25" kv="0.05"
                  ctrlrange="-2.356 2.356" forcerange="-0.20 0.20"/>
    </actuator>
</mujoco>