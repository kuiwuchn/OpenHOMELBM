<mujoco model="Eel3D_RibbonFish_Obstacle">
    <compiler angle="degree" inertiafromgeom="true"/>
    <option timestep="0.01" gravity="0 0 0" integrator="RK4"/>
    
    <default>
        <joint damping="0.2" stiffness="0" armature="0.02"/>
        <motor ctrlrange="-1 1" ctrllimited="true"/>
        <geom solref="0.002 1" solimp="0.9 0.95 0.001"/>
    </default>
    
    <asset>
        <!-- Gradient from a dark head to a light tail. -->
        <material name="seg1_mat" rgba="0.15 0.15 0.4 1"/>
        <material name="seg2_mat" rgba="0.2 0.25 0.5 1"/>
        <material name="seg3_mat" rgba="0.25 0.35 0.55 1"/>
        <material name="seg4_mat" rgba="0.3 0.45 0.6 1"/>
        <material name="seg5_mat" rgba="0.4 0.55 0.65 1"/>
        <material name="seg6_mat" rgba="0.5 0.6 0.7 1"/>
        <material name="seg7_mat" rgba="0.6 0.7 0.8 1"/>
        <material name="seg8_mat" rgba="0.75 0.8 0.9 1"/>
        <material name="obstacle_mat" rgba="0.8 0.2 0.2 0.8"/>
    </asset>
    
    <worldbody>
        <!-- Static jointless obstacle. -->
        <!-- Positioned between the eel start and target. -->
        <!-- MuJoCo y offset is 0.4 m, near normalized LBM y=0.62. -->
        <!-- The vertical pillar blocks a straight path. -->
        <body name="obstacle" pos="0.0 0.4 0.0">
            <!-- No joint keeps the obstacle fixed in world space. -->
            <geom name="obstacle_geom" type="box"
                  size="0.06 0.015 0.025"
                  pos="0 0 0"
                  material="obstacle_mat"
                  density="8000"
                  contype="1" conaffinity="1"/>
        </body>
        
        <!-- Body segment 1: head. -->
        <!-- Each link uses paired yaw and roll joints. -->
        <!-- Eight segments use seven joint pairs. -->
        <body name="seg1" pos="0 0 0">
            <freejoint name="root_joint"/>
            
            <!-- Flat box: x=0.008, y=0.06, z=0.05. -->
            <geom name="seg1_geom" type="box"
                  size="0.004 0.03 0.025"
                  pos="0 0 0"
                  material="seg1_mat"
                  density="5000"/>
            
            <!-- Body segment 2. -->
            <body name="seg2" pos="0 -0.03 0">
                <!-- Yaw around z for lateral motion. -->
                <joint name="joint1_yaw" type="hinge" axis="0 0 1" limited="true" range="-35 35"/>
                <!-- Roll around y. -->
                <joint name="joint1_roll" type="hinge" axis="0 1 0" limited="true" range="-30 30"/>
                
                <geom name="seg2_geom" type="box"
                      size="0.004 0.03 0.025"
                      pos="0 -0.03 0"
                      material="seg2_mat"
                      density="5000"/>
                
                <!-- Body segment 3. -->
                <body name="seg3" pos="0 -0.06 0">
                    <joint name="joint2_yaw" type="hinge" axis="0 0 1" limited="true" range="-35 35"/>
                    <joint name="joint2_roll" type="hinge" axis="0 1 0" limited="true" range="-30 30"/>
                    
                    <geom name="seg3_geom" type="box"
                          size="0.004 0.03 0.025"
                          pos="0 -0.03 0"
                          material="seg3_mat"
                          density="5000"/>
                    
                    <!-- Body segment 4. -->
                    <body name="seg4" pos="0 -0.06 0">
                        <joint name="joint3_yaw" type="hinge" axis="0 0 1" limited="true" range="-40 40"/>
                        <joint name="joint3_roll" type="hinge" axis="0 1 0" limited="true" range="-35 35"/>
                        
                        <geom name="seg4_geom" type="box"
                              size="0.004 0.03 0.025"
                              pos="0 -0.03 0"
                              material="seg4_mat"
                              density="4500"/>
                        
                        <!-- Body segment 5. -->
                        <body name="seg5" pos="0 -0.06 0">
                            <joint name="joint4_yaw" type="hinge" axis="0 0 1" limited="true" range="-40 40"/>
                            <joint name="joint4_roll" type="hinge" axis="0 1 0" limited="true" range="-35 35"/>
                            
                            <geom name="seg5_geom" type="box"
                                  size="0.004 0.03 0.025"
                                  pos="0 -0.03 0"
                                  material="seg5_mat"
                                  density="4000"/>
                            
                            <!-- Body segment 6. -->
                            <body name="seg6" pos="0 -0.06 0">
                                <joint name="joint5_yaw" type="hinge" axis="0 0 1" limited="true" range="-45 45"/>
                                <joint name="joint5_roll" type="hinge" axis="0 1 0" limited="true" range="-40 40"/>
                                
                                <geom name="seg6_geom" type="box"
                                      size="0.004 0.03 0.025"
                                      pos="0 -0.03 0"
                                      material="seg6_mat"
                                      density="3500"/>
                                
                                <!-- Body segment 7. -->
                                <body name="seg7" pos="0 -0.06 0">
                                    <joint name="joint6_yaw" type="hinge" axis="0 0 1" limited="true" range="-45 45"/>
                                    <joint name="joint6_roll" type="hinge" axis="0 1 0" limited="true" range="-40 40"/>
                                    
                                    <geom name="seg7_geom" type="box"
                                          size="0.004 0.03 0.025"
                                          pos="0 -0.03 0"
                                          material="seg7_mat"
                                          density="3000"/>
                                    
                                    <!-- Body segment 8: tail. -->
                                    <body name="seg8" pos="0 -0.06 0">
                                        <joint name="joint7_yaw" type="hinge" axis="0 0 1" limited="true" range="-50 50"/>
                                        <joint name="joint7_roll" type="hinge" axis="0 1 0" limited="true" range="-45 45"/>
                                        
                                        <geom name="seg8_geom" type="box"
                                              size="0.004 0.03 0.025"
                                              pos="0 -0.03 0"
                                              material="seg8_mat"
                                              density="2500"/>
                                    </body>
                                </body>
                            </body>
                        </body>
                    </body>
                </body>
            </body>
        </body>
        
        <light directional="true" diffuse="0.9 0.9 0.9" pos="0 0 3" dir="0 0 -1"/>
    </worldbody>
    
    <actuator>
        <!-- Fourteen position actuators for seven joint pairs. -->
        <position name="pos1_yaw" joint="joint1_yaw" kp="2.0" kv="0.2" ctrlrange="-0.873 0.873" forcerange="-1.0 1.0"/>
        <position name="pos1_roll" joint="joint1_roll" kp="2.0" kv="0.2" ctrlrange="-0.785 0.785" forcerange="-1.0 1.0"/>
        
        <position name="pos2_yaw" joint="joint2_yaw" kp="2.0" kv="0.2" ctrlrange="-0.873 0.873" forcerange="-1.0 1.0"/>
        <position name="pos2_roll" joint="joint2_roll" kp="2.0" kv="0.2" ctrlrange="-0.785 0.785" forcerange="-1.0 1.0"/>
        
        <position name="pos3_yaw" joint="joint3_yaw" kp="2.0" kv="0.2" ctrlrange="-0.873 0.873" forcerange="-1.0 1.0"/>
        <position name="pos3_roll" joint="joint3_roll" kp="2.0" kv="0.2" ctrlrange="-0.785 0.785" forcerange="-1.0 1.0"/>
        
        <position name="pos4_yaw" joint="joint4_yaw" kp="2.0" kv="0.2" ctrlrange="-0.873 0.873" forcerange="-1.0 1.0"/>
        <position name="pos4_roll" joint="joint4_roll" kp="2.0" kv="0.2" ctrlrange="-0.785 0.785" forcerange="-1.0 1.0"/>
        
        <position name="pos5_yaw" joint="joint5_yaw" kp="2.0" kv="0.2" ctrlrange="-0.873 0.873" forcerange="-1.0 1.0"/>
        <position name="pos5_roll" joint="joint5_roll" kp="2.0" kv="0.2" ctrlrange="-0.785 0.785" forcerange="-1.0 1.0"/>
        
        <position name="pos6_yaw" joint="joint6_yaw" kp="2.0" kv="0.2" ctrlrange="-0.873 0.873" forcerange="-1.0 1.0"/>
        <position name="pos6_roll" joint="joint6_roll" kp="2.0" kv="0.2" ctrlrange="-0.785 0.785" forcerange="-1.0 1.0"/>
        
        <position name="pos7_yaw" joint="joint7_yaw" kp="2.0" kv="0.2" ctrlrange="-0.873 0.873" forcerange="-1.0 1.0"/>
        <position name="pos7_roll" joint="joint7_roll" kp="2.0" kv="0.2" ctrlrange="-0.785 0.785" forcerange="-1.0 1.0"/>
    </actuator>
</mujoco>
