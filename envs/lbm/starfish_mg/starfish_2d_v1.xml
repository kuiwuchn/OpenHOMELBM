<mujoco model="Starfish2D_Swimmer">

    <compiler angle="degree" inertiafromgeom="true"/>
    <option timestep="0.01" gravity="0 0 0" integrator="RK4"/>

    <default>
        <joint damping="0.05" stiffness="0" armature="0.01"/>
        <motor ctrlrange="-1 1" ctrllimited="true"/>
        <geom solref="0.001 1" solimp="0.9 0.95 0.001"/>
    </default>

    <asset>
        <material name="center" rgba="1.0 0.5 0.2 1"/>
        <material name="arm"    rgba="1.0 0.7 0.4 1"/>
    </asset>

    <worldbody>
        <geom type="plane" size="5 5 0.1" rgba="0.1 0.1 0.1 1" pos="0 0 0"/>

        <!-- 中心体 -->
        <body name="root" pos="0 0 0.05">
            <joint name="free_xy" type="free"/>

            <!-- 中心圆盘 -->
            <geom name="center_geom" type="cylinder"
                  size="0.06 0.02"
                  material="center"
                  density="500"/>

            <!-- 上臂 (向+y方向) -->
            <body name="arm_up" pos="0 0.06 0">
                <joint name="joint_up" type="hinge" axis="0 0 1" range="-60 60" pos="0 0 0"/>
                <geom name="arm_up_geom" type="capsule"
                      fromto="0 0 0  0 0.12 0"
                      size="0.025"
                      material="arm"
                      density="500"/>
            </body>

            <!-- 下臂 (向-y方向) -->
            <body name="arm_down" pos="0 -0.06 0">
                <joint name="joint_down" type="hinge" axis="0 0 1" range="-60 60" pos="0 0 0"/>
                <geom name="arm_down_geom" type="capsule"
                      fromto="0 0 0  0 -0.12 0"
                      size="0.025"
                      material="arm"
                      density="500"/>
            </body>

            <!-- 左臂 (向-x方向) -->
            <body name="arm_left" pos="-0.06 0 0">
                <joint name="joint_left" type="hinge" axis="0 0 1" range="-60 60" pos="0 0 0"/>
                <geom name="arm_left_geom" type="capsule"
                      fromto="0 0 0  -0.12 0 0"
                      size="0.025"
                      material="arm"
                      density="500"/>
            </body>

            <!-- 右臂 (向+x方向) -->
            <body name="arm_right" pos="0.06 0 0">
                <joint name="joint_right" type="hinge" axis="0 0 1" range="-60 60" pos="0 0 0"/>
                <geom name="arm_right_geom" type="capsule"
                      fromto="0 0 0  0.12 0 0"
                      size="0.025"
                      material="arm"
                      density="500"/>
            </body>
        </body>
        <light directional="true" diffuse="0.9 0.9 0.9" pos="0 0 5" dir="0 0 -1"/>
    </worldbody>

    <actuator>
        <motor joint="joint_up" gear="0.15"/>
        <motor joint="joint_down" gear="0.15"/>
        <motor joint="joint_left" gear="0.15"/>
        <motor joint="joint_right" gear="0.15"/>
    </actuator>

</mujoco>
