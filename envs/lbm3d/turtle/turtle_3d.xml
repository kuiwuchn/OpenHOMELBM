<mujoco model="SeaTurtle3D_Swimmer">
    <!--
    Sea Turtle 3D Robot for LBM-MuJoCo Coupled Simulation  (v5 — ball-like shoulder)
    
    Reference: 3D rendered sea turtle — rounded dome shell, single-segment
    front flippers (crescent shape), rounded head, short paddle rear
    flippers, small triangular tail.
    
    Structure:
      shell (freejoint, 6DOF root)
        head (fixed, no joints)
        flipper_FR (3DOF ball-like: rotate along flipper axis + flap Y + sweep Z)
        flipper_FL (mirrored)
        flipper_RR (2DOF: rotate Z + flap X)
        flipper_RL (mirrored)
        tail (1DOF: yaw Z)
    
    Total actuators: 9 DOF  (2*2 front + 2*2 rear + 1 tail; sweep commented out)
    Coordinate: X=lateral(right+), Y=forward, Z=up
    
    Mesh generated at 1x; scale="1.1 1.1 1.1" applied here (smaller for boundary margin).
    Approximate body dimensions (after 1.1x scale):
      Shell:  ~0.099 x 0.137 x 0.072 m
      Front flipper: ~0.077m span each
      Rear flipper: ~0.017m wide x 0.015m long
      Head+neck: ~0.047m long
    -->

    <compiler angle="degree" inertiafromgeom="true" meshdir="meshes/"/>
    <option timestep="0.01" gravity="0 0 0" integrator="RK4"/>

    <default>
        <joint damping="0.35" stiffness="0" armature="0.12"/>
        <motor ctrlrange="-1 1" ctrllimited="true"/>
        <geom solref="0.002 1" solimp="0.9 0.95 0.001"/>
    </default>

    <asset>
        <!-- Materials: olive/green-brown sea turtle coloring -->
        <material name="shell_mat"          rgba="0.30 0.35 0.20 1"/>
        <material name="head_mat"           rgba="0.35 0.40 0.25 1"/>
        <material name="flipper_front_mat"  rgba="0.28 0.33 0.22 1"/>
        <material name="flipper_rear_mat"   rgba="0.32 0.36 0.24 1"/>
        <material name="tail_mat"           rgba="0.35 0.38 0.28 1"/>

        <!-- Meshes (scale 1.1x — reduced from 1.4x for better boundary margin) -->
        <mesh name="shell_mesh"             file="turtle_shell.stl"             scale="1.1 1.1 1.1"/>
        <mesh name="head_mesh"              file="turtle_head.stl"              scale="1.1 1.1 1.1"/>
        <mesh name="flipper_front_R_mesh"   file="turtle_flipper_front_R.stl"   scale="1.1 1.1 1.1"/>
        <mesh name="flipper_front_L_mesh"   file="turtle_flipper_front_L.stl"   scale="1.1 1.1 1.1"/>
        <mesh name="flipper_rear_R_mesh"    file="turtle_flipper_rear_R.stl"    scale="1.1 1.1 1.1"/>
        <mesh name="flipper_rear_L_mesh"    file="turtle_flipper_rear_L.stl"    scale="1.1 1.1 1.1"/>
        <mesh name="tail_mesh"              file="turtle_tail.stl"              scale="1.1 1.1 1.1"/>
    </asset>

    <worldbody>
        <body name="shell" pos="0 0 0">
            <freejoint name="root_joint"/>

            <geom name="shell_geom" type="mesh" mesh="shell_mesh"
                  material="shell_mat" density="1800"/>

            <!-- ============ HEAD (fixed to shell front) ============ -->
            <!-- Head position scaled to match 1.1x mesh -->
            <body name="head" pos="0 0.044 0.0066">
                <geom name="head_geom" type="mesh" mesh="head_mesh"
                      material="head_mat" density="2500"/>
            </body>

            <!-- ============ FRONT RIGHT FLIPPER (3DOF ball-like shoulder) ============ -->
            <!-- Shoulder: 3 hinge joints emulating a ball joint -->
            <!-- Z=CG plane (0.0076) to avoid lift bias from offset -->
            <body name="flipper_FR" pos="0.0418 0.0358 0.0076" euler="0 0 23">
                <joint name="f_FR_flap" type="hinge" axis="0 1 0"
                       limited="true" range="-45 45"/>
                <joint name="f_FR_rotate" type="hinge" axis="0.920 -0.392 0.0"
                       limited="true" range="-60 60"
                       damping="0.50" armature="0.12"/>
                <!-- <joint name="f_FR_sweep" type="hinge" axis="0 0 1" -->
                       <!-- limited="true" range="-35 35"/> -->

                <geom name="f_FR_geom" type="mesh" mesh="flipper_front_R_mesh"
                      material="flipper_front_mat" density="2200"/>
            </body>

            <!-- ============ FRONT LEFT FLIPPER (3DOF ball-like shoulder, mirrored) ============ -->
            <!-- Z=CG plane (0.0076) to avoid lift bias from offset -->
            <body name="flipper_FL" pos="-0.0418 0.0358 0.0076" euler="0 0 -23">
                <joint name="f_FL_flap" type="hinge" axis="0 1 0"
                       limited="true" range="-45 45"/>
                <joint name="f_FL_rotate" type="hinge" axis="-0.920 -0.392 0.0"
                       limited="true" range="-60 60"
                       damping="0.50" armature="0.12"/>
                <!-- <joint name="f_FL_sweep" type="hinge" axis="0 0 1"
                       limited="true" range="-35 35"/> -->

                <geom name="f_FL_geom" type="mesh" mesh="flipper_front_L_mesh"
                      material="flipper_front_mat" density="2200"/>
            </body>

            <!-- ============ REAR RIGHT FLIPPER (webbed foot, pointing backward) ============ -->
            <!-- Hip joint on CG plane (Z=0.0076) to avoid lift bias -->
            <body name="flipper_RR" pos="0.0407 -0.055 0.0076">
                <joint name="f_RR_rotate" type="hinge" axis="0 0 1"
                       limited="true" range="-5 50"
                       damping="0.12" armature="0.05"/>
                <joint name="f_RR_flap" type="hinge" axis="1 0 0"
                       limited="true" range="-40 40"/>

                <geom name="f_RR_geom" type="mesh" mesh="flipper_rear_R_mesh"
                      material="flipper_rear_mat" density="2000"/>
            </body>

            <!-- ============ REAR LEFT FLIPPER (mirrored, pointing backward) ============ -->
            <body name="flipper_RL" pos="-0.0407 -0.055 0.0076">
                <joint name="f_RL_rotate" type="hinge" axis="0 0 1"
                       limited="true" range="-50 5"
                       damping="0.12" armature="0.05"/>
                <joint name="f_RL_flap" type="hinge" axis="1 0 0"
                       limited="true" range="-40 40"/>

                <geom name="f_RL_geom" type="mesh" mesh="flipper_rear_L_mesh"
                      material="flipper_rear_mat" density="2000"/>
            </body>

            <!-- ============ TAIL ============ -->
            <!-- Tail base on CG plane (Z=0.0076) to avoid lift bias -->
            <body name="tail" pos="0 -0.0627 0.0076">
                <joint name="tail_yaw" type="hinge" axis="0 0 1"
                       limited="true" range="-35 35"/>

                <geom name="tail_geom" type="mesh" mesh="tail_mesh"
                      material="tail_mat" density="1800"/>
            </body>
        </body>

        <light directional="true" diffuse="0.9 0.9 0.9" pos="0 0 3" dir="0 0 -1"/>
    </worldbody>

    <actuator>
        <!--
        Actuator layout (9 DOFs, sweep commented out):
          [0]  f_FR_rotate    Front-right: rotation (twist around Y)
          [1]  f_FR_flap      Front-right: up-down flap (around X)
          [2]  f_FL_rotate    Front-left: rotation (twist around Y)
          [3]  f_FL_flap      Front-left: up-down flap (around X)
          [4]  f_RR_rotate    Rear-right: rotation (twist)
          [5]  f_RR_flap      Rear-right: up-down flap
          [6]  f_RL_rotate    Rear-left: rotation (twist)
          [7]  f_RL_flap      Rear-left: up-down flap
          [8]  tail_yaw       Tail: yaw
        -->

        <!-- Front-right flipper: 3 DOFs (ball-like shoulder) -->
        <position name="pos_f_FR_rotate" joint="f_FR_rotate" kp="5.0" kv="0.30"
                  ctrlrange="-0.864 0.864" forcerange="-3.0 3.0"/>
        <position name="pos_f_FR_flap"   joint="f_FR_flap"   kp="4.0" kv="0.15"
                  ctrlrange="-1.047 1.047" forcerange="-3.0 3.0"/>
        <!-- <position name="pos_f_FR_sweep"  joint="f_FR_sweep"  kp="1.4" kv="0.20"
                  ctrlrange="-0.611 0.611" forcerange="-0.8 0.8"/> -->

        <!-- Front-left flipper: 3 DOFs (ball-like shoulder) -->
        <position name="pos_f_FL_rotate" joint="f_FL_rotate" kp="5.0" kv="0.30"
                  ctrlrange="-0.864 0.864" forcerange="-3.0 3.0"/>
        <position name="pos_f_FL_flap"   joint="f_FL_flap"   kp="4.0" kv="0.15"
                  ctrlrange="-1.047 1.047" forcerange="-3.0 3.0"/>
        <!-- <position name="pos_f_FL_sweep"  joint="f_FL_sweep"  kp="1.4" kv="0.20" -->
                  <!-- ctrlrange="-0.611 0.611" forcerange="-0.8 0.8"/> -->

        <!-- Rear-right flipper: 2 DOFs -->
        <position name="pos_f_RR_rotate" joint="f_RR_rotate" kp="3.0" kv="0.10"
                  ctrlrange="-0.576 0.576" forcerange="-2.0 2.0"/>
        <position name="pos_f_RR_flap"   joint="f_RR_flap"   kp="2.5" kv="0.10"
                  ctrlrange="-0.698 0.698" forcerange="-1.5 1.5"/>

        <!-- Rear-left flipper: 2 DOFs -->
        <position name="pos_f_RL_rotate" joint="f_RL_rotate" kp="3.0" kv="0.10"
                  ctrlrange="-0.576 0.576" forcerange="-2.0 2.0"/>
        <position name="pos_f_RL_flap"   joint="f_RL_flap"   kp="2.5" kv="0.10"
                  ctrlrange="-0.698 0.698" forcerange="-1.5 1.5"/>

        <!-- Tail: 1 DOF -->
        <position name="pos_tail_yaw" joint="tail_yaw" kp="0.8" kv="0.12"
                  ctrlrange="-0.611 0.611" forcerange="-0.5 0.5"/>
    </actuator>
</mujoco>
